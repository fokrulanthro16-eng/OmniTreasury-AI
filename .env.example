# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=OmniTreasury AI
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ─── AI / LLM (required for CrewAI agents) ────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ─── UiPath Maestro ───────────────────────────────────────────────────────────
UIPATH_ORG_ID=your_org_id
UIPATH_TENANT_NAME=your_tenant
UIPATH_CLIENT_ID=your_client_id
UIPATH_CLIENT_SECRET=your_client_secret
UIPATH_MAESTRO_URL=https://cloud.uipath.com
UIPATH_FOLDER_PATH=Shared

# ─── FX Data Feed ─────────────────────────────────────────────────────────────
FX_API_KEY=your_fx_api_key
FX_API_URL=https://api.exchangerate-api.com/v4

# ─── Decision Thresholds ──────────────────────────────────────────────────────
AUTO_APPROVE_MAX_AMOUNT=500000
RISK_ESCALATION_THRESHOLD=60
HIGH_RISK_THRESHOLD=80
COMPLIANCE_FUZZY_MATCH_THRESHOLD=75
MATERIALITY_THRESHOLD=1000000

# ─── Mock Flags (set true to run without real APIs) ───────────────────────────
USE_MOCK_DATA=true
USE_MOCK_FX=true
USE_MOCK_BANKING=true
USE_MOCK_MAESTRO=true
